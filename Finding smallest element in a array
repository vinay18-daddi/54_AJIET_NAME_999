class Main {
    public static void main(String[] args) {
      
        int [] a = {1,5,8,10};
        int smallest = a[0];
        for(int i=0;i< a.length ;i++)
        {
            if(a[i] < smallest)
           smallest= a[i];
        }
        System.out.println("Smallest element in a array :"+smallest);
    }
}
